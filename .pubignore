# Files / directories excluded from the tarball uploaded to pub.dev.
# This is on top of pub's own default ignores (.git/, .dart_tool/, build/, …).
# Anything excluded here is still kept in the GitHub repo; we only trim
# what consumers don't need.

# Tests are useful in the repo but not for consumers; they would bloat the
# tarball by megabytes and pub.dev does not render them anywhere.
test/

# Erlang/rebar3 artefacts (shouldn't normally exist in a Flutter package
# but keep ignored just in case something leaks in).
_build/

# Dartdoc HTML output is regenerated by pub.dev itself on publish.
doc/api/

# Workflows are part of the repo, not the package. pub.dev doesn't run
# them and they only confuse the file listing.
.github/

# Maintainer / contributor docs that aren't referenced from README. README
# + CHANGELOG + LICENSE + ARCHITECTURE/INTEGRATION/TESTING are kept because
# the README links to them.
RELEASING.md
CONTRIBUTING.md
