# Dart / Flutter
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
build/
**/build/
**/.dart_tool/

# Pub
# Packages SHOULD NOT commit pubspec.lock (it is regenerated by consumers).
# Apps usually do; the example/ here is a demo, so we ignore its lockfile
# to avoid drift with the parent package.
pubspec.lock
example/pubspec.lock

# Generated dartdoc output (regenerated by pub.dev on publish)
doc/api/

# Erlang/rebar3 artefacts (should not be present in a Flutter package
# but keep ignored just in case)
_build/

# Test failures and coverage
test/**/failures/
coverage/
.coverage/

# IDE / editor
.idea/
.vscode/
*.iml
*.swp
*~

# macOS / OS
.DS_Store
Thumbs.db
